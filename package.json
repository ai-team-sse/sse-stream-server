{
  "name": "sse-stream-server-monorepo",
  "version": "1.0.0",
  "description": "SSE Stream Server - Monorepo",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=server",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=server",
    "build:server": "npm run build --workspace=server",
    "start": "npm run start --workspace=server",
    "start:server": "npm run start --workspace=server",
    "test": "npm run test --workspace=server",
    "test:server": "npm run test --workspace=server",
    "test:watch": "npm run test:watch --workspace=server",
    "test:ui": "npm run test:ui --workspace=server",
    "test:coverage": "npm run test:coverage --workspace=server",
    "lint": "npm run lint --workspace=server",
    "lint:fix": "npm run lint:fix --workspace=server",
    "format": "npm run format --workspace=server",
    "format:check": "npm run format:check --workspace=server",
    "clean": "npm run clean --workspaces --if-present",
    "install:all": "npm install"
  },
  "keywords": [
    "sse",
    "server-sent-events",
    "monorepo"
  ],
  "author": "",
  "license": "MIT"
}
